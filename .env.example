# AgentBus Environment Configuration
# Copy this to .env.local and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agentbus"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AgentBus"

# Blockchain (Base mainnet/testnet)
NEXT_PUBLIC_CHAIN_ID="8453"
NEXT_PUBLIC_RPC_URL="https://sepolia.base.org"

# Smart Contract Addresses (Base mainnet)
NEXT_PUBLIC_AGENT_NFT_ADDRESS="0xb085E4795fC252FE167E900bcAf221DE87FD7218"
NEXT_PUBLIC_TREASURY_ADDRESS="0x880550A2e000a80c39C95F8c1e80D825373BA189"
NEXT_PUBLIC_BATTLE_ARENA_ADDRESS="0x615107651E62498705DF8F1eC53b68e787fFAcDF"
NEXT_PUBLIC_LAUNCHPAD_ADDRESS="0xD6A1Cd4Dc4ec801f0B454596489b642E7C8D0465"
NEXT_PUBLIC_AGNTBUS_TOKEN_ADDRESS="0x5AAD90bcC905ed276d13566C98D158C2FD0376dD"

# Optional: Redis for caching
# REDIS_URL="redis://localhost:6379"

# Optional: IPFS for metadata storage
# IPFS_GATEWAY="https://ipfs.io/ipfs/"
# IPFS_API_URL="https://ipfs.infura.io:5001"

# Farcaster Integration (Neynar API)
# Get your API key from https://neynar.com/
NEYNAR_API_KEY="your-neynar-api-key-here"

# Venice AI — Image generation + model inference
# Get your API key from https://venice.ai/settings/api
VENICE_API_KEY="your-venice-api-key-here"

# Litebeam — Universal microservice routing via MCP + x402 micropayments
# Sign up at https://litebeam.xyz/signup
LITEBEAM_API_KEY="your-litebeam-api-key-here"

# Agent Wallet Configuration
# See scripts/wallets.json for full wallet details
NEXT_PUBLIC_AGENT_WALLET_DEX="0x1AdFF92A279B529C6E0e1de33c00aAaB95f7bc74"
